# Social Agent — Salão 365°
# Copie este arquivo para .env e preencha com seus dados reais.
# No Railway, configure como variáveis de ambiente (não suba o .env).

# ── Claude API ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── ClickUp ───────────────────────────────────────────────────────────────────
CLICKUP_API_TOKEN=pk_...
CLICKUP_LIST_ID=                        # ID da lista kanban (número)

# ── ClickUp Custom Fields (preencher após criar os campos) ────────────────────
# Obter via: GET https://api.clickup.com/api/v2/list/{CLICKUP_LIST_ID}/field
CF_PERSONA=                             # dropdown: jessica | carla | leo
CF_FUNIL=                               # dropdown: tofu | mofu | bofu
CF_FORMATO=                             # dropdown: reels | carrossel | card | story
CF_REDES=                               # labels: instagram, tiktok, youtube
CF_HOOK=                                # dropdown: numero | dor | promessa | erro
CF_HORARIO=                             # short text: HH:MM
CF_GANCHO=                              # long text
CF_TEMA_ID=                             # short text: ex J-T01
CF_ROTEIRO=                             # long text (saída do agent)
CF_COPY_IG=                             # long text (saída do agent)
CF_COPY_TK=                             # long text (saída do agent)
CF_COPY_YT=                             # long text (saída do agent)
CF_BRIEFING=                            # long text JSON (saída do agent)
CF_MEDIA_URL=                           # short text: URL do asset aprovado

# ── Instagram Graph API ───────────────────────────────────────────────────────
IG_ACCESS_TOKEN=                        # token de longa duração (60 dias)
IG_BUSINESS_ID=                         # ID da conta business do Instagram

# ── TikTok Content Posting API v2 ─────────────────────────────────────────────
TIKTOK_ACCESS_TOKEN=                    # token OAuth2 da TikTok for Developers

# ── YouTube Data API v3 ───────────────────────────────────────────────────────
YOUTUBE_CLIENT_ID=                      # OAuth2 client ID do Google Cloud Console
YOUTUBE_CLIENT_SECRET=                  # OAuth2 client secret
YOUTUBE_REFRESH_TOKEN=                  # refresh token gerado uma vez via OAuth flow

# ── Notificações SMTP (Gmail) ─────────────────────────────────────────────────
SMTP_USER=seu@gmail.com
SMTP_PASS=                              # senha de app do Gmail (16 chars, sem espaços)
NOTIFY_EMAIL=seu@gmail.com             # destinatário das notificações

# ── Web server ────────────────────────────────────────────────────────────────
PORT=8080
AGENT_TOKEN=                            # token secreto para /run/planner e /run/execute
